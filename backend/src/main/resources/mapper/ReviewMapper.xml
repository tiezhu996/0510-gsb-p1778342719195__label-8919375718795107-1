<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fruitshop.mapper.ReviewMapper">

    <resultMap id="ReviewResultMap" type="com.fruitshop.entity.Review">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="order_item_id" property="orderItemId"/>
        <result column="user_id" property="userId"/>
        <result column="fruit_id" property="fruitId"/>
        <result column="rating" property="rating"/>
        <result column="content" property="content"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findById" resultMap="ReviewResultMap">
        SELECT * FROM review WHERE id = #{id}
    </select>

    <select id="findByOrderItemId" resultMap="ReviewResultMap">
        SELECT * FROM review WHERE order_item_id = #{orderItemId}
    </select>

    <select id="findByOrderId" resultMap="ReviewResultMap">
        SELECT * FROM review WHERE order_id = #{orderId}
    </select>

    <select id="findByUserId" resultMap="ReviewResultMap">
        SELECT * FROM review WHERE user_id = #{userId}
    </select>

    <insert id="insert" parameterType="com.fruitshop.entity.Review" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO review (order_id, order_item_id, user_id, fruit_id, rating, content, create_time, update_time)
        VALUES (#{orderId}, #{orderItemId}, #{userId}, #{fruitId}, #{rating}, #{content},
                #{createTime}, #{updateTime})
    </insert>

    <select id="countByOrderId" resultType="int">
        SELECT COUNT(*) FROM review WHERE order_id = #{orderId}
    </select>

</mapper>
