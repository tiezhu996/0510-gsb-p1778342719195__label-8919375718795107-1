<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fruitshop.mapper.FruitMapper">

    <resultMap id="FruitResultMap" type="com.fruitshop.entity.Fruit">
        <id column="id" property="id"/>
        <result column="category_id" property="categoryId"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="price" property="price"/>
        <result column="original_price" property="originalPrice"/>
        <result column="unit" property="unit"/>
        <result column="stock" property="stock"/>
        <result column="sales" property="sales"/>
        <result column="main_image" property="mainImage"/>
        <result column="images" property="images"/>
        <result column="detail" property="detail"/>
        <result column="origin" property="origin"/>
        <result column="status" property="status"/>
        <result column="is_hot" property="isHot"/>
        <result column="is_new" property="isNew"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findById" resultMap="FruitResultMap">
        SELECT * FROM fruit WHERE id = #{id}
    </select>

    <select id="findByCondition" resultMap="FruitResultMap">
        SELECT * FROM fruit WHERE status = 1
        <if test="categoryId != null">
            AND category_id = #{categoryId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND name LIKE CONCAT('%', #{keyword}, '%')
        </if>
        <choose>
            <when test="sort == 'price_asc'">
                ORDER BY price ASC
            </when>
            <when test="sort == 'price_desc'">
                ORDER BY price DESC
            </when>
            <when test="sort == 'sales'">
                ORDER BY sales DESC
            </when>
            <when test="sort == 'new'">
                ORDER BY create_time DESC
            </when>
            <otherwise>
                ORDER BY sales DESC
            </otherwise>
        </choose>
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*) FROM fruit WHERE status = 1
        <if test="categoryId != null">
            AND category_id = #{categoryId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND name LIKE CONCAT('%', #{keyword}, '%')
        </if>
    </select>

    <select id="findHotFruits" resultMap="FruitResultMap">
        SELECT * FROM fruit WHERE status = 1 AND is_hot = 1 ORDER BY sales DESC LIMIT #{limit}
    </select>

    <select id="findNewFruits" resultMap="FruitResultMap">
        SELECT * FROM fruit WHERE status = 1 AND is_new = 1 ORDER BY create_time DESC LIMIT #{limit}
    </select>

    <update id="updateStock">
        UPDATE fruit SET stock = stock - #{quantity}, update_time = NOW() WHERE id = #{id} AND stock >= #{quantity}
    </update>

    <update id="updateSales">
        UPDATE fruit SET sales = sales + #{quantity}, update_time = NOW() WHERE id = #{id}
    </update>

</mapper>
