<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fruitshop.mapper.OrderItemMapper">

    <resultMap id="OrderItemResultMap" type="com.fruitshop.entity.OrderItem">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="fruit_id" property="fruitId"/>
        <result column="fruit_name" property="fruitName"/>
        <result column="fruit_image" property="fruitImage"/>
        <result column="spec_name" property="specName"/>
        <result column="price" property="price"/>
        <result column="quantity" property="quantity"/>
        <result column="subtotal" property="subtotal"/>
    </resultMap>

    <select id="findByOrderId" resultMap="OrderItemResultMap">
        SELECT * FROM order_item WHERE order_id = #{orderId}
    </select>

    <insert id="insert" parameterType="com.fruitshop.entity.OrderItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO order_item (order_id, fruit_id, fruit_name, fruit_image, spec_name, price, quantity, subtotal)
        VALUES (#{orderId}, #{fruitId}, #{fruitName}, #{fruitImage}, #{specName}, #{price}, #{quantity}, #{subtotal})
    </insert>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO order_item (order_id, fruit_id, fruit_name, fruit_image, spec_name, price, quantity, subtotal)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.orderId}, #{item.fruitId}, #{item.fruitName}, #{item.fruitImage},
             #{item.specName}, #{item.price}, #{item.quantity}, #{item.subtotal})
        </foreach>
    </insert>

    <delete id="deleteByOrderId">
        DELETE FROM order_item WHERE order_id = #{orderId}
    </delete>

</mapper>
