<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fruitshop.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="com.fruitshop.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="icon" property="icon"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findAll" resultMap="CategoryResultMap">
        SELECT * FROM category WHERE status = 1 ORDER BY sort ASC
    </select>

    <select id="findById" resultMap="CategoryResultMap">
        SELECT * FROM category WHERE id = #{id}
    </select>

</mapper>
